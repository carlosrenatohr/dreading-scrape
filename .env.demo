# --- MongoDB ---
# Local Docker stack: use a full connection string (DB_URI wins over the parts below).
DB_URI="mongodb://mongo:27017"
DB_NAME="dailyreading"
# MongoDB Atlas (leave DB_URI empty to build a mongodb+srv:// URI from these):
DB_HOST=""
DB_USERNAME=""
DB_PASSWORD=""

# --- Redis ---
# Local Docker stack: plain Redis, no auth, no TLS.
UPSTACK_ENDPOINT="redis"
UPSTACK_PORT=6379
UPSTACK_PASSWORD=
# Set UPSTACK_SSL=true for Upstash (requires TLS); false for local Redis.
UPSTACK_SSL=false

# --- AI enrichment ---
# Default is an offline deterministic stub (no key). Switch to a real LLM with:
#   ENRICH_PROVIDER=llm
# and an OpenAI-compatible endpoint. Example — Cloudflare Workers AI (free tier):
#   ENRICH_API_URL=https://api.cloudflare.com/client/v4/accounts/<ACCOUNT_ID>/ai/v1/chat/completions
#   ENRICH_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast
#   ENRICH_API_KEY=<Cloudflare API token>
# (Groq / Gemini's OpenAI-compat / Ollama also work by changing these three.)
ENRICH_PROVIDER=stub
